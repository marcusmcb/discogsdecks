# Server
PORT=5000
SESSION_SECRET=replace-me-with-a-long-random-string

# Database
# Use Neon (recommended to start) or a local Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Discogs App (create at https://www.discogs.com/settings/developers)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# Discogs dump ingestion (vinyl-only serving index)
# MongoDB (recommended for the catalog serving index)
MONGODB_URI=
MONGODB_DB=discogsdecks
MONGODB_CATALOG_COLLECTION=discogs_catalog_vinyl

# S3-compatible object storage for raw dumps + processed artifacts.
# Recommended for cost: Cloudflare R2.
OBJECT_STORE_BUCKET=
OBJECT_STORE_REGION=auto
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_ACCESS_KEY_ID=
OBJECT_STORE_SECRET_ACCESS_KEY=
OBJECT_STORE_PREFIX=discogs
